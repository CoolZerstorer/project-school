    fields_frame.pack(padx=25, fill="both", expand=True, pady=5)
    
    lbl_opts = {"font": ("Segoe UI", 9, "bold"), "bg": "#1E1E24", "fg": "#A0A0AB", "anchor": "w"}
    ent_opts = {"font": ("Segoe UI", 11), "bg": "#2A2A35", "fg": "white", "insertbackground": "white", "relief": "flat", "bd": 5}
    
    field_keys = ["Book Name:", "Student ID:", "Student Name:", "Date (YYYY-MM-DD):", "Accumulated Fine (₹):"]
    entry_widgets = []
    
    for i, label_name in enumerate(field_keys):
        tk.Label(fields_frame, text=label_name, **lbl_opts).pack(anchor="w", pady=(6,2))
        ent = tk.Entry(fields_frame, **ent_opts)
        ent.pack(fill="x", pady=(0, 8))
        entry_widgets.append(ent)
        
    up_book_name, up_student_id, up_student_name, up_date_issue, up_fine = entry_widgets

    def fetch_target_record():
        b_id = search_id_entry.get().strip()
        if not b_id or not b_id.isdigit():
            messagebox.showwarning("Input Missing", "Please enter a valid numeric Book ID!", parent=update_window)
            return
            
        try:
            conn = mysql.connector.connect(host="127.0.0.1", user="root", password="root123456", database="student_db")
            cursor = conn.cursor()
            cursor.execute("SELECT book_name, student_id, student_name, date_of_issue, fine FROM books_issued WHERE book_id = %s;", (int(b_id),))
            record = cursor.fetchone()
            
            if not record:
                messagebox.showerror("Not Found", f"No active issue records discovered matching Book ID: {b_id}", parent=update_window)
                return
                
            for e in entry_widgets: e.delete(0, tk.END)
            
            up_book_name.insert(0, record[0])
            up_student_id.insert(0, record[1])
            up_student_name.insert(0, record[2])
            date_val = record[3].strftime('%Y-%m-%d') if hasattr(record[3], 'strftime') else str(record[3])
            up_date_issue.insert(0, date_val)
            up_fine.insert(0, str(record[4]))
            
            messagebox.showinfo("Loaded", "Record fetched successfully! You can now apply structural mutations.", parent=update_window)
        except Error as e:
            messagebox.showerror("Error", f"Could not read row structural logs: {e}", parent=update_window)
        finally:
            if 'conn' in locals() and conn.is_connected():
                cursor.close()
                conn.close()

    def commit_updates():
        b_id = search_id_entry.get().strip()
        b_name = up_book_name.get().strip()
        s_id = up_student_id.get().strip()
        s_name = up_student_name.get().strip()
        d_issue = up_date_issue.get().strip()
        f_amt = up_fine.get().strip()
        
        if not b_id or not b_name or not s_id or not s_name or not d_issue or f_amt == "":
            messagebox.showwarning("Validation Error", "All fields must be completely filled out before saving updates!", parent=update_window)
            return
            
        if not f_amt.isdigit():
            messagebox.showerror("Input Error", "Fine layout value structure must be a valid whole number integer string!", parent=update_window)
            return

        try:
            datetime.strptime(d_issue, "%Y-%m-%d")
        except ValueError:
            messagebox.showerror("Format Error", "Date must strictly use the YYYY-MM-DD format structure!", parent=update_window)
            return
            
        try:
            conn = mysql.connector.connect(host="127.0.0.1", user="root", password="root123456", database="student_db")
            cursor = conn.cursor()
            query = "UPDATE books_issued SET book_name = %s, student_id = %s, student_name = %s, date_of_issue = %s, fine = %s WHERE book_id = %s;"
            cursor.execute(query, (b_name, s_id, s_name, d_issue, int(f_amt), int(b_id)))
            conn.commit()
            messagebox.showinfo("Success", "Library schema modifications saved successfully!", parent=update_window)
            update_window.destroy() 
        except Error as e:
            messagebox.showerror("Database Execution Error", f"Could not update fields: {e}", parent=update_window)
        finally:
            if 'conn' in locals() and conn.is_connected():
                cursor.close()
                conn.close()

    fetch_btn = tk.Button(fetch_frame, text="Pull Record", font=("Segoe UI", 9, "bold"), bg="#2F80ED", fg="white", command=fetch_target_record, relief="flat", padx=10)
    fetch_btn.grid(row=0, column=2, padx=10, pady=15)
    
    btn_control_frame = tk.Frame(update_window, bg="#2A2A35", height=70)
    btn_control_frame.pack(fill="x", side="bottom")
    
    save_btn = tk.Button(btn_control_frame, text="Commit Schema Updates", font=("Segoe UI", 10, "bold"), bg="#2F80ED", fg="white", activebackground="#1B60B8", activeforeground="white", relief="flat", width=22, height=2, command=commit_updates)
    save_btn.pack(pady=12, side="right", padx=25)


