def open_login_screen():
    login_win = tk.Toplevel(root)
    login_win.title("Secure Gatekeeper Identity Access Verification Module")
    center_window(login_win, 380, 380)
    login_win.configure(bg="#1E1E24")
    
    def on_login_close():
        root.destroy()
    login_win.protocol("WM_DELETE_WINDOW", on_login_close)

    # Top Accent bar decoration pattern layout frame integration
    accent_bar = tk.Frame(login_win, height=4, bg="#2F80ED")
    accent_bar.pack(fill="x", side="top")

    tk.Label(login_win, text="SECURITY ACCESS", font=("Segoe UI", 14, "bold"), bg="#1E1E24", fg="#FFFFFF").pack(pady=(35, 25))

    lbl_opts = {"font": ("Segoe UI", 9, "bold"), "bg": "#1E1E24", "fg": "#A0A0AB"}
    ent_opts = {"font": ("Segoe UI", 11), "bg": "#2A2A35", "fg": "white", "insertbackground": "white", "relief": "flat", "bd": 6}

    tk.Label(login_win, text="Administrator Identity ID", **lbl_opts).pack(anchor="w", padx=40, pady=(10, 2))
    username_entry = tk.Entry(login_win, **ent_opts)
    username_entry.pack(fill="x", padx=40, pady=2)
    username_entry.focus()

    tk.Label(login_win, text="System Verification Token", **lbl_opts).pack(anchor="w", padx=40, pady=(15, 2))
    
    password_frame = tk.Frame(login_win, bg="#1E1E24")
    password_frame.pack(fill="x", padx=40, pady=2)

    password_entry = tk.Entry(password_frame, show="*", **ent_opts)
    password_entry.pack(side=tk.LEFT, fill="x", expand=True)

    def toggle_password():
        if password_entry.cget("show") == "*":
            password_entry.config(show="")
            toggle_btn.config(text="Hide", bg="#3A3A45")
        else:
            password_entry.config(show="*")
            toggle_btn.config(text="Show", bg="#2A2A35")

    toggle_btn = tk.Button(password_frame, text="Show", font=("Segoe UI", 8, "bold"), command=toggle_password, width=6, bg="#2A2A35", fg="#A0A0AB", activebackground="#3A3A45", activeforeground="white", relief="flat", bd=0, height=2)
    toggle_btn.pack(side=tk.RIGHT, padx=(5, 0))

    def check_login():
        if username_entry.get().strip() == "admin" and password_entry.get() == "secret123":
            messagebox.showinfo("Success", "Authorisation Token verified successfully!", parent=login_win)
            login_win.destroy()
            root.deiconify() 
        else:
            messagebox.showerror("Access Denied", "Invalid administrative identity mapping tokens.", parent=login_win)

    login_win.bind('<Return>', lambda event: check_login())

    login_button = tk.Button(login_win, text="Authenticate System Access", font=("Segoe UI", 10, "bold"), command=check_login, bg="#2F80ED", fg="white", activebackground="#1B60B8", activeforeground="white", relief="flat", height=2)
    login_button.pack(fill="x", padx=40, pady=35)


