    header_frame.pack(fill="x", side="top")
    tk.Label(header_frame, text="Modify Record Fields", font=("Segoe UI", 13, "bold"), bg="#252529", fg="white").pack(side="left", padx=20, pady=15)

    fetch_frame = tk.LabelFrame(update_window, text=" Find Record by Book ID ", font=("Segoe UI", 9, "bold"), bg="#1c1c1e", fg="#007aff", bd=1, relief="solid")
    fetch_frame.pack(padx=20, fill="x", pady=10)
    
    tk.Label(fetch_frame, text="Enter Book ID to Modify:", font=("Segoe UI", 10, "bold"), bg="#1c1c1e", fg="#a1a1a6").grid(row=0, column=0, padx=10, pady=10, sticky="w")
    search_id_entry = tk.Entry(fetch_frame, font=("Segoe UI", 11), width=10, bg="#252529", fg="white", insertbackground="white", relief="flat", bd=4)
    search_id_entry.grid(row=0, column=1, padx=5, pady=10)
    
    fields_frame = tk.Frame(update_window, bg="#1c1c1e")
    fields_frame.pack(padx=20, fill="both", expand=True, pady=5)
    
    lbl_opts = {"font": ("Segoe UI", 9, "bold"), "bg": "#1c1c1e", "fg": "#a1a1a6", "anchor": "w"}
    ent_opts = {"font": ("Segoe UI", 11), "bg": "#252529", "fg": "white", "insertbackground": "white", "relief": "flat", "bd": 4}
    
    field_keys = ["Book Name:", "Student ID:", "Student Name:", "Date (YYYY-MM-DD):", "Accumulated Fine (₹):"]
    entry_widgets = []
    
    for label_name in field_keys:
        tk.Label(fields_frame, text=label_name, **lbl_opts).pack(anchor="w", pady=(4,2))
        ent = tk.Entry(fields_frame, **ent_opts)
        ent.pack(fill="x", pady=(0, 6))
        entry_widgets.append(ent)
        
    up_book_name, up_student_id, up_student_name, up_date_issue, up_fine = entry_widgets

    def fetch_target_record():
        b_id = search_id_entry.get().strip()
        if not b_id or not b_id.isdigit():
            messagebox.showwarning("Input Missing", "Please enter a valid numeric Book ID!", parent=update_window)
            return
            
        try:
            conn = mysql.connector.connect(host="127.0.0.1", user="root", password="root123456", database="student_db")
            cursor = conn.cursor()
            cursor.execute("SELECT book_name, student_id, student_name, date_of_issue, fine FROM books_issued WHERE book_id = %s;", (int(b_id),))
            record = cursor.fetchone()
            
            if not record:
                messagebox.showerror("Not Found", f"No active issue records discovered matching Book ID: {b_id}", parent=update_window)
                return
                
            for e in entry_widgets: e.delete(0, tk.END)
            
            up_book_name.insert(0, record[0])
            up_student_id.insert(0, record[1])
            up_student_name.insert(0, record[2])
            date_val = record[3].strftime('%Y-%m-%d') if hasattr(record[3], 'strftime') else str(record[3])
            up_date_issue.insert(0, date_val)
            up_fine.insert(0, str(record[4]))
            
            messagebox.showinfo("Loaded", "Record fetched successfully!", parent=update_window)
        except Error as e:
            messagebox.showerror("Error", f"Could not read row: {e}", parent=update_window)
        finally:
            if 'conn' in locals() and conn.is_connected():
                cursor.close()
                conn.close()

    def commit_updates():
        b_id = search_id_entry.get().strip()
        b_name = up_book_name.get().strip()
        s_id = up_student_id.get().strip()
        s_name = up_student_name.get().strip()
        d_issue = up_date_issue.get().strip()
        f_amt = up_fine.get().strip()
        
        if not b_id or not b_name or not s_id or not s_name or not d_issue or f_amt == "":
            messagebox.showwarning("Validation Error", "All fields must be completely filled out before saving updates!", parent=update_window)
            return
            
        if not f_amt.isdigit():
            messagebox.showerror("Input Error", "Fine value must be a valid whole number!", parent=update_window)
            return

        try:
            datetime.strptime(d_issue, "%Y-%m-%d")
        except ValueError:
            messagebox.showerror("Format Error", "Date must strictly use the YYYY-MM-DD format!", parent=update_window)
            return
            
        try:
            conn = mysql.connector.connect(host="127.0.0.1", user="root", password="root123456", database="student_db")
            cursor = conn.cursor()
            query = "UPDATE books_issued SET book_name = %s, student_id = %s, student_name = %s, date_of_issue = %s, fine = %s WHERE book_id = %s;"
            cursor.execute(query, (b_name, s_id, s_name, d_issue, int(f_amt), int(b_id)))
            conn.commit()
            messagebox.showinfo("Success", "Library records updated successfully!", parent=update_window)
            update_window.destroy() 
        except Error as e:
            messagebox.showerror("Database Error", f"Could not update fields: {e}", parent=update_window)
        finally:
            if 'conn' in locals() and conn.is_connected():
                cursor.close()
                conn.close()

    fetch_btn = tk.Button(fetch_frame, text="Find/Load", font=("Segoe UI", 9, "bold"), bg="#007aff", fg="white", command=fetch_target_record, relief="flat", padx=10)
    fetch_btn.grid(row=0, column=2, padx=10, pady=10)
    
    btn_control_frame = tk.Frame(update_window, bg="#252529", height=60)
    btn_control_frame.pack(fill="x", side="bottom")
    
    tk.Button(btn_control_frame, text="Save Updates", font=("Segoe UI", 10, "bold"), bg="#007aff", fg="white", activebackground="#0056b3", relief="flat", width=16, command=commit_updates).pack(pady=12, side="right", padx=20)


