            cursor.execute("INSERT INTO archived_books (book_id, student_id, student_name, date_of_issue, book_name) VALUES (%s, %s, %s, %s, %s);", (int(vals[0]), vals[1], vals[2], vals[3], vals[4]))
            cursor.execute("DELETE FROM books_issued WHERE book_id = %s;", (int(vals[0]),))
            conn.commit()
            messagebox.showinfo("Returned Successfully", "Record archived safely! Active layout restored cleanly.", parent=tables_window)
            load_table_records()  
        except Error as e:
            messagebox.showerror("Database Error", f"Could not finalize storage transaction logs safely: {e}", parent=tables_window)
        finally:
            if 'conn' in locals() and conn.is_connected():
                cursor.close()
                conn.close()

    btn_control_frame = tk.Frame(tables_window, bg="#2A2A35", height=70)
    btn_control_frame.pack(fill="x", side="bottom")
    
    return_btn = tk.Button(btn_control_frame, text="Mark Selection As Returned / Archive Data Log", font=("Segoe UI", 10, "bold"), bg="#2ED573", fg="white", activebackground="#219653", activeforeground="white", relief="flat", padx=20, pady=10, command=clear_selected_record)
    return_btn.pack(pady=15, side="right", padx=25)

    load_table_records()


