            messagebox.showwarning("Selection Warning", "Please click on a record row from the table list first to clear it!", parent=tables_window)
            return
            
        vals = tree.item(selected_item)['values']
        confirm = messagebox.askyesno("Confirm Return Authorization", f"Mark Book ID {vals[0]} as returned by {vals[2]}?\nThis executes an irreversible archive mapping logic step.", parent=tables_window)
