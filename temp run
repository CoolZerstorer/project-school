def open_register_window():
    reg_window = create_styled_toplevel("Register Student Book Issue", 500, 500)
    
    header_frame = tk.Frame(reg_window, bg="#252529", height=60)
    header_frame.pack(fill="x", side="top")
    header_frame.pack_propagate(False)
    tk.Label(header_frame, text="Book Registration Form", font=("Segoe UI", 14, "bold"), bg="#252529", fg="white").pack(side="left", padx=20, pady=15)

    form_frame = tk.Frame(reg_window, bg="#1c1c1e")
    form_frame.pack(padx=30, pady=20, fill="both", expand=True)

    lbl_opts = {"font": ("Segoe UI", 10, "bold"), "bg": "#1c1c1e", "fg": "#a1a1a6", "anchor": "w"}
    ent_opts = {"font": ("Segoe UI", 11), "bg": "#252529", "fg": "white", "insertbackground": "white", "relief": "flat", "bd": 5}

    fields = [
        ("Book ID :", "book_id"),
        ("Book Name:", "book_name"),
        ("Student ID:", "student_id"),
        ("Student Name:", "student_name"),
        ("Date (YYYY-MM-DD):", "date_issue")
    ]
    
    entries = {}
    for idx, (label_text, key) in enumerate(fields):
        tk.Label(form_frame, text=label_text, **lbl_opts).grid(row=idx*2, column=0, sticky="w", pady=(6, 2))
        entry = tk.Entry(form_frame, **ent_opts)
        entry.grid(row=idx*2+1, column=0, sticky="ew", pady=(0, 8))
        entries[key] = entry

    entries["date_issue"].insert(0, datetime.today().strftime('%Y-%m-%d'))

    def submit_action():
        b_id = entries["book_id"].get().strip()
        s_id = entries["student_id"].get().strip()
        s_name = entries["student_name"].get().strip()
        b_name = entries["book_name"].get().strip()
        d_issue = entries["date_issue"].get().strip()
        
        if not b_id or not s_id or not s_name or not d_issue or not b_name:
            messagebox.showwarning("Missing Information", "Please fill out all fields before submitting!", parent=reg_window)
            return
        
        if not b_id.isdigit():
            messagebox.showerror("Input Error", "Book ID must be a valid integer number!", parent=reg_window)
            return
            
        try:
            datetime.strptime(d_issue, "%Y-%m-%d")
        except ValueError:
            messagebox.showerror("Format Error", "Date must strictly use the YYYY-MM-DD format!", parent=reg_window)
            return

        try:
            conn = mysql.connector.connect(host="127.0.0.1", user="root", password="root123456", database="student_db")
            cursor = conn.cursor()
            query = "INSERT INTO books_issued (book_id, student_id, student_name, date_of_issue, book_name, fine) VALUES (%s, %s, %s, %s, %s, 0);"
            cursor.execute(query, (int(b_id), s_id, s_name, d_issue, b_name))
            conn.commit()
            
            messagebox.showinfo("Success", f"Successfully registered record for {s_name}!", parent=reg_window)
            reg_window.destroy()
        except mysql.connector.Error as err:
            messagebox.showerror("Database Error", f"Failed to save record: {err}", parent=reg_window)
        finally:
            if 'conn' in locals() and conn.is_connected():
                cursor.close()
                conn.close()

    def clear_action():
        for entry in entries.values():
            entry.delete(0, tk.END)
        entries["date_issue"].insert(0, datetime.today().strftime('%Y-%m-%d'))

    form_frame.columnconfigure(0, weight=1)

    btn_frame = tk.Frame(reg_window, bg="#252529", height=60)
    btn_frame.pack(fill="x", side="bottom")
    
    tk.Button(btn_frame, text="Clear Fields", font=("Segoe UI", 10, "bold"), bg="#3a3a3c", fg="white", activebackground="#48484a", activeforeground="white", relief="flat", width=12, command=clear_action).pack(side="left", padx=20, pady=12)
    tk.Button(btn_frame, text="Submit Data", font=("Segoe UI", 10, "bold"), bg="#007aff", fg="white", activebackground="#0056b3", activeforeground="white", relief="flat", width=14, command=submit_action).pack(side="right", padx=20, pady=12)


