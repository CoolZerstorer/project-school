    ent_opts = {"font": ("Segoe UI", 11), "bg": "#252529", "fg": "white", "insertbackground": "white", "relief": "flat", "bd": 5}

    tk.Label(login_win, text="Administrator Identity ID", **lbl_opts).pack(anchor="w", padx=35, pady=(5, 2))
    username_entry = tk.Entry(login_win, **ent_opts)
    username_entry.pack(fill="x", padx=35, pady=2)
    username_entry.focus()

    tk.Label(login_win, text="System Verification Token", **lbl_opts).pack(anchor="w", padx=35, pady=(12, 2))
    
    password_frame = tk.Frame(login_win, bg="#1c1c1e")
    password_frame.pack(fill="x", padx=35, pady=2)

    password_entry = tk.Entry(password_frame, show="*", **ent_opts)
    password_entry.pack(side=tk.LEFT, fill="x", expand=True)

    def toggle_password():
        if password_entry.cget("show") == "*":
            password_entry.config(show="")
            toggle_btn.config(text="Hide", bg="#3a3a3c")
        else:
            password_entry.config(show="*")
            toggle_btn.config(text="Show", bg="#252529")

    toggle_btn = tk.Button(password_frame, text="Show", font=("Segoe UI", 8, "bold"), command=toggle_password, width=6, bg="#252529", fg="#a1a1a6", activebackground="#3a3a3c", activeforeground="white", relief="flat", bd=0, height=2)
    toggle_btn.pack(side=tk.RIGHT, padx=(5, 0))

    def check_login():
        if username_entry.get().strip() == "admin" and password_entry.get() == "secret123":
            messagebox.showinfo("Success", "Authorisation Token verified successfully!", parent=login_win)
            login_win.destroy()
            root.deiconify() 
        else:
            messagebox.showerror("Access Denied", "Invalid administration match pairs.", parent=login_win)

    login_win.bind('<Return>', lambda event: check_login())

    login_button = tk.Button(login_win, text="Authenticate System", font=("Segoe UI", 10, "bold"), command=check_login, bg="#007aff", fg="white", activebackground="#0056b3", activeforeground="white", relief="flat", height=2)
    login_button.pack(fill="x", padx=35, pady=30)


