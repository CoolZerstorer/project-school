import tkinter as tk
from tkinter import messagebox

def check_login():
    # Retrieve data from input fields
    username = username_entry.get()
    password = password_entry.get()
    
    # Simple credential validation check
    if username == "admin" and password == "secret123":
        messagebox.showinfo("Success", "Login successful!")
    else:
        messagebox.showerror("Error", "Invalid username or password.")

def toggle_password():
    # Check current masking character and toggle it
    if password_entry.cget("show") == "*":
        password_entry.config(show="")
        toggle_btn.config(text="Hide")
    else:
        password_entry.config(show="*")
        toggle_btn.config(text="Show")

# Initialize root application window
root = tk.Tk()
root.title("Secure Login Form")
root.geometry("350x200")

# Username layout elements
username_label = tk.Label(root, text="Username:")
username_label.pack(pady=(15, 2))
username_entry = tk.Entry(root, width=25)
username_entry.pack(pady=2)

# Password layout elements
password_label = tk.Label(root, text="Password:")
password_label.pack(pady=(10, 2))

# The frame groups the entry widget side-by-side with the visibility button
password_frame = tk.Frame(root)
password_frame.pack(pady=2)

# Setting show="*" masks user keyboard inputs to asterisks
password_entry = tk.Entry(password_frame, show="*", width=18)
password_entry.pack(side=tk.LEFT)

toggle_btn = tk.Button(password_frame, text="Show", command=toggle_password, width=5)
toggle_btn.pack(side=tk.LEFT, padx=(5, 0))

# Submit authorization request
login_button = tk.Button(root, text="Login", command=check_login, width=15)
login_button.pack(pady=20)

root.mainloop()
